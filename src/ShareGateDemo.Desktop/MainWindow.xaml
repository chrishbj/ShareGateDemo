<Window x:Class="ShareGateDemo.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShareGateDemo.Desktop"
        mc:Ignorable="d"
        Title="ShareGate Migrate Demo" Height="600" Width="980">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Create Job" Margin="0,0,0,12"/>

            <TextBlock Text="API Endpoint"/>
            <ComboBox ItemsSource="{Binding Endpoints}"
                      SelectedItem="{Binding SelectedEndpoint}"
                      DisplayMemberPath="Name"
                      Margin="0,4,0,6"/>
            <Button Content="Use Endpoint" Command="{Binding SwitchEndpointCommand}" Height="30" Margin="0,0,0,12"/>

            <TextBlock Text="Name"/>
            <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

            <TextBlock Text="Source"/>
            <TextBox Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

            <TextBlock Text="Target"/>
            <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

            <TextBlock Text="Note"/>
            <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Height="80" AcceptsReturn="True"/>

            <Button Content="Create Job" Command="{Binding CreateCommand}" Height="34" Margin="0,4,0,8"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Height="34" Margin="0,0,0,8"/>
            <Button Content="Run Selected" Command="{Binding RunCommand}" Height="34"/>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Migration Jobs" Margin="0,0,0,12"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Jobs}"
                      SelectedItem="{Binding SelectedJob}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="2*"/>
                    <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="2*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                    <DataGridTextColumn Header="Updated (UTC)" Binding="{Binding UpdatedAtUtc}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
